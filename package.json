{
  "name": "jerry-james-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-astro.mjs dev",
    "build": "prettier --check . && eslint . && node scripts/run-astro.mjs build",
    "preview": "node scripts/run-astro.mjs preview",
    "check:static": "node scripts/run-astro.mjs build",
    "check:seo": "node scripts/check-seo.mjs",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "lint": "eslint .",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/krub": "^5.2.7",
    "astro": "^6.3.3",
    "gsap": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "browserslist": "^4.24.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "lightningcss": "^1.29.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1"
  }
}
