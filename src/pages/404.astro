---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteContent } from '../content.js';

const profile = siteContent.profile;
const title = `Page not found - ${profile.name}`;
const description =
  'This page was announced but never shipped. Head back to the homepage or browse the blog.';
---

<BaseLayout title={title} description={description} page="blog" noindex>
  <SiteNav current="" />
  <main id="main-content" class="blog-shell">
    <section class="blog-hero">
      <div class="container blog-hero-inner not-found">
        <svg
          class="not-found-graphic"
          viewBox="0 0 280 200"
          role="img"
          aria-label="A monogram-style ring containing the number 404, its orbital signal line breaking apart on one side"
        >
          <defs>
            <linearGradient
              id="nf-ring"
              x1="68"
              y1="28"
              x2="212"
              y2="172"
              gradientUnits="userSpaceOnUse"
            >
              <stop stop-color="#90D5FF"></stop>
              <stop offset="1" stop-color="#517891"></stop>
            </linearGradient>
            <linearGradient
              id="nf-orbit"
              x1="10"
              y1="95"
              x2="270"
              y2="105"
              gradientUnits="userSpaceOnUse"
            >
              <stop stop-color="#57B9FF"></stop>
              <stop offset=".5" stop-color="#90D5FF"></stop>
              <stop offset="1" stop-color="#57B9FF"></stop>
            </linearGradient>
            <linearGradient
              id="nf-gloss"
              x1="120"
              y1="68"
              x2="160"
              y2="132"
              gradientUnits="userSpaceOnUse"
            >
              <stop stop-color="#D6EFFF"></stop>
              <stop offset=".45" stop-color="#57B9FF"></stop>
              <stop offset="1" stop-color="#517891"></stop>
            </linearGradient>
            <filter
              id="nf-glow"
              x="-20%"
              y="-20%"
              width="140%"
              height="140%"
              color-interpolation-filters="sRGB"
            >
              <feGaussianBlur stdDeviation="3"></feGaussianBlur>
            </filter>
          </defs>

          <circle
            class="nf-halo"
            cx="140"
            cy="100"
            r="72"
            fill="none"
            stroke="rgba(87, 185, 255, 0.45)"
            stroke-width="5"
            filter="url(#nf-glow)"></circle>
          <circle
            cx="140"
            cy="100"
            r="72"
            fill="rgba(7, 9, 12, 0.72)"
            stroke="url(#nf-ring)"
            stroke-width="2.5"></circle>

          <text
            class="nf-code"
            x="140"
            y="103"
            text-anchor="middle"
            dominant-baseline="central"
            fill="url(#nf-gloss)">404</text
          >

          <path
            class="nf-orbit-solid"
            d="M10 100c63-21 197-21 260 0"
            fill="none"
            stroke="url(#nf-orbit)"
            stroke-width="2.25"
            stroke-linecap="round"
            pathLength="100"
            stroke-dasharray="66 34"></path>
          <path
            class="nf-orbit-fragments"
            d="M10 100c63-21 197-21 260 0"
            fill="none"
            stroke="url(#nf-orbit)"
            stroke-width="2.25"
            stroke-linecap="round"
            pathLength="100"
            stroke-dasharray="0 70 5 6 3 7 1.5 100"></path>
          <circle class="nf-blip" cx="200" cy="87.5" r="3.5" fill="#90D5FF"
          ></circle>
        </svg>

        <p class="blog-kicker">Error 404 · Signal lost</p>
        <h1 class="blog-title">You found the vaporware.</h1>
        <p class="blog-intro">
          This page was announced by your URL bar, but it never shipped. Could
          be a typo, could be a link that outlived its redirect. Everything
          below, though, is in production.
        </p>
        <div class="not-found-actions">
          <a href="/" class="btn btn--primary">Back to production</a>
          <a href="/blog/" class="btn btn--outline">Browse the field notes</a>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter backHref="/" />
</BaseLayout>
