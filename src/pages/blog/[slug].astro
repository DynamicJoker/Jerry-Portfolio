---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { siteContent } from '../../content.js';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const profile = siteContent.profile;
const canonical = new URL(`/blog/${post.id}/`, profile.canonicalUrl).href;
const formatDate = (date) =>
  new Intl.DateTimeFormat('en', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  }).format(date);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  image: new URL(post.data.coverImage, profile.canonicalUrl).href,
  url: canonical,
  author: {
    '@type': 'Person',
    name: profile.name,
    url: profile.canonicalUrl
  }
};
---

<BaseLayout
  title={`${post.data.title} - ${profile.name}`}
  description={post.data.description}
  canonical={canonical}
  image={post.data.coverImage}
  type="article"
  page="blog"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)}></script>
  <SiteNav current="blog" />
  <main class="article-shell">
    <article class="article-layout">
      <header class="article-header">
        <a href="/blog/" class="article-back">Blog</a>
        <div class="article-meta">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          {
            post.data.updatedDate && (
              <span>Updated {formatDate(post.data.updatedDate)}</span>
            )
          }
        </div>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
        <div class="article-tags">
          {post.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </header>

      <img class="article-cover" src={post.data.coverImage} alt={post.data.coverAlt} />

      <div class="article-content">
        <Content />
      </div>

      <footer class="article-cta">
        <p>Need technical content that makes complex products easier to buy?</p>
        <a href="/#contact" class="btn btn--primary">Start a conversation</a>
      </footer>
    </article>
  </main>
  <SiteFooter backHref="/blog/" />
</BaseLayout>
