---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { siteContent } from '../../content.js';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(
    (post) => !post.data.draft,
  );

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const profile = siteContent.profile;
const canonical = new URL(`/blog/${post.id}/`, profile.canonicalUrl).href;
const socialImage = post.data.socialImage ?? post.data.coverImage;
const socialImageAlt = post.data.socialImageAlt ?? post.data.coverAlt;
const socialImageWidth = post.data.socialImageWidth ?? post.data.coverWidth;
const socialImageHeight = post.data.socialImageHeight ?? post.data.coverHeight;
const formatDate = (date) =>
  new Intl.DateTimeFormat('en', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(date);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  image: {
    '@type': 'ImageObject',
    url: new URL(socialImage, profile.canonicalUrl).href,
    width: socialImageWidth,
    height: socialImageHeight,
    caption: socialImageAlt,
  },
  url: canonical,
  author: {
    '@id': new URL('/#person', profile.canonicalUrl).href,
  },
  publisher: {
    '@id': new URL('/#person', profile.canonicalUrl).href,
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: profile.canonicalUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: new URL('/blog/', profile.canonicalUrl).href,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: canonical,
    },
  ],
};
---

<BaseLayout
  title={`${post.data.title} - ${profile.name}`}
  description={post.data.description}
  canonical={canonical}
  image={socialImage}
  imageAlt={socialImageAlt}
  imageWidth={socialImageWidth}
  imageHeight={socialImageHeight}
  type="article"
  page="blog"
  structuredData={[articleJsonLd, breadcrumbJsonLd]}
>
  <Fragment slot="head">
    <meta
      property="article:published_time"
      content={post.data.pubDate.toISOString()}
    />
    <meta
      property="article:modified_time"
      content={(post.data.updatedDate ?? post.data.pubDate).toISOString()}
    />
    {post.data.tags.map((tag) => <meta property="article:tag" content={tag} />)}
  </Fragment>
  <SiteNav current="blog" />
  <main class="article-shell">
    <article class="article-layout">
      <header class="article-header">
        <a href="/blog/" class="article-back">Blog</a>
        <div class="article-meta">
          <time datetime={post.data.pubDate.toISOString()}
            >{formatDate(post.data.pubDate)}</time
          >
          {
            post.data.updatedDate && (
              <span>Updated {formatDate(post.data.updatedDate)}</span>
            )
          }
        </div>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
        <div class="article-tags">
          {post.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </header>

      <img
        class="article-cover"
        src={post.data.coverImage}
        alt={post.data.coverAlt}
        width={post.data.coverWidth}
        height={post.data.coverHeight}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />

      <div class="article-content">
        <Content />
      </div>

      <footer class="article-cta">
        <p>Need technical content that makes complex products easier to buy?</p>
        <a href="/#contact" class="btn btn--primary">Start a conversation</a>
      </footer>
    </article>
  </main>
  <SiteFooter backHref="/blog/" />
</BaseLayout>
