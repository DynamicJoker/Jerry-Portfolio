---
import { siteContent } from '../content.js';
import Icon from './Icon.astro';
import SiteFooter from './SiteFooter.astro';

const profile = siteContent.profile;

// Gantt data: period strings must be 'MM/YYYY - MM/YYYY' (or '- Present').
const jobs = siteContent.experience
  .map((job) => {
    const [startStr, endStr] = job.period.split(' - ');
    const [startMonth, startYear] = startStr.split('/');
    const startDate = new Date(`${startYear}-${startMonth}-01`);
    let endDate =
      endStr.toLowerCase() === 'present'
        ? new Date()
        : new Date(`${endStr.split('/')[1]}-${endStr.split('/')[0]}-01`);
    return { ...job, startDate, endDate };
  })
  .sort((a, b) => a.sortOrder - b.sortOrder);

const firstDate = new Date(Math.min(...jobs.map((j) => j.startDate)));
const lastDate = new Date(Math.max(...jobs.map((j) => j.endDate)));
const totalDuration = lastDate.getTime() - firstDate.getTime();

const ganttYears = [];
for (let y = firstDate.getFullYear(); y <= lastDate.getFullYear(); y++) {
  ganttYears.push(y);
}

function getGanttDurationText(startDate, endDate) {
  const totalMonths = Math.max(
    1,
    (endDate.getFullYear() - startDate.getFullYear()) * 12 +
      endDate.getMonth() -
      startDate.getMonth(),
  );
  const years = Math.floor(totalMonths / 12);
  const months = totalMonths % 12;
  const parts = [];

  if (years > 0) {
    parts.push(`${years} ${years === 1 ? 'yr' : 'yrs'}`);
  }

  if (months > 0 || parts.length === 0) {
    parts.push(`${months} ${months === 1 ? 'mo' : 'mos'}`);
  }

  return parts.join(' ');
}

// Featured work: flagship spotlights + a filterable archive of the full body of
// work. The archive is grouped category -> campaign -> rows; an industry filter
// narrows it. Each row's `status` drives its badge + link via `workStatusMeta`.
const featuredCampaigns = siteContent.featuredCampaigns;
const workTypeMeta = siteContent.workTypeMeta;
const workStatusMeta = siteContent.workStatusMeta;
const workArchive = siteContent.workArchive;
const industryOrder = [
  'PC Hardware',
  'Cybersecurity',
  'Cloud',
  'Software / SaaS',
];
const industryRank = (x) => {
  const i = industryOrder.indexOf(x);
  return i === -1 ? 99 : i;
};
const archiveIndustries = [...new Set(workArchive.map((p) => p.industry))].sort(
  (a, b) => industryRank(a) - industryRank(b),
);
const assetTypeLabels = siteContent.assetTypeLabels;
const assetTypeOrder = [
  'Product Launch',
  'Case studies & Customer stories',
  'Reviews',
  'Guides & Explainers',
  'Landing pages & Web copy',
  'Blogs & Articles',
  'Press & PR',
  'Other',
];
const assetRank = (x) => {
  const i = assetTypeOrder.indexOf(x);
  return i === -1 ? 99 : i;
};
// Archive: asset-type chip-tabs (single-select) + an industry chip filter over a
// flat, sorted list. `assetTypes` drives the tab bar; `archiveRows` is sorted by
// type, then industry, then newest-first.
const assetTypes = [...new Set(workArchive.map((p) => p.assetType))]
  .sort((a, b) => assetRank(a) - assetRank(b))
  .map((assetType) => ({
    assetType,
    count: workArchive.filter((p) => p.assetType === assetType).length,
  }));
const firstType = assetTypes[0]?.assetType;
const archiveRows = [...workArchive].sort((a, b) => {
  const byType = assetRank(a.assetType) - assetRank(b.assetType);
  if (byType) return byType;
  const byIndustry = industryRank(a.industry) - industryRank(b.industry);
  if (byIndustry) return byIndustry;
  return (b.year || '').localeCompare(a.year || '');
});
const archiveHasLink = (status) =>
  status === 'live' || status === 'press' || status === 'archived';

const numColumns = 3;
const testimonialColumns = Array.from({ length: numColumns }, () => []);
siteContent.testimonials.forEach((testimonial, index) => {
  testimonialColumns[index % numColumns].push(testimonial);
});
---

<main id="main-content">
  <!-- Hero Section -->
  <section id="hero" class="c-hero">
    <div class="c-hero__background" aria-hidden="true">
      <div class="c-hero__grid"></div>
      <div class="c-hero__aurora">
        <span class="c-hero__aurora-bloom c-hero__aurora-bloom--1"></span>
        <span class="c-hero__aurora-bloom c-hero__aurora-bloom--2"></span>
        <span class="c-hero__aurora-bloom c-hero__aurora-bloom--3"></span>
      </div>
    </div>
    <div class="c-hero__inner">
      <div class="c-hero__lead">
        <p class="c-hero__eyebrow">
          <span class="c-hero__eyebrow-role">{profile.jobTitle}</span>
          <a
            class="c-hero__status"
            href="#schedule"
            aria-label={`${profile.availability.status}, go to scheduling section`}
          >
            <span
              class="c-availability-dot c-hero__status-dot"
              aria-hidden="true"></span>
            <span>{profile.availability.status}</span>
          </a>
        </p>
        <h1 class="c-hero__name">{profile.name}</h1>
        <p class="c-hero__headline">
          {profile.heroHeadline.pre}<span class="c-hero__headline-accent"
            >{profile.heroHeadline.accent}</span
          >{profile.heroHeadline.post}
        </p>
        <p class="c-hero__lede">{profile.heroLede}</p>
        <div class="c-hero__buttons">
          <a href="#portfolio" class="c-btn c-btn--primary c-btn--lg"
            >View Portfolio</a
          >
          <a href="#schedule" class="c-btn c-btn--outline c-btn--lg"
            >Book a Discovery Call</a
          >
        </div>
        <ul class="c-hero__meta">
          <li class="c-hero__meta-item">
            <span id="years-experience"
              >{new Date().getFullYear() - profile.experienceStartYear}</span
            >+ yrs
          </li>
          <li class="c-hero__meta-item">
            {profile.location.city}, {profile.location.country}
          </li>
          <li class="c-hero__meta-item">{profile.heroFocus}</li>
        </ul>
      </div>
      <div class="c-hero__panel">
        <div class="c-hero__portrait">
          <img
            src={profile.portraitImage}
            alt={profile.portraitAlt}
            class="c-hero__portrait-img"
            width="300"
            height="300"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        <div class="c-hero__proof">
          <span class="c-hero__proof-tag" aria-hidden="true">proof</span>
          <dl class="c-hero__metrics">
            {
              profile.heroStats.map((stat) => (
                <div class="c-hero__metric">
                  <dt class="c-hero__metric-value">{stat.value}</dt>
                  <dd class="c-hero__metric-label">{stat.label}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </div>
    <a
      href="#about"
      class="c-scroll-indicator"
      aria-label="Scroll to next section"
    >
      <div class="c-scroll-indicator__arrow"></div>
    </a>
  </section>

  <!-- About Section -->
  <section id="about" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">About</span></span
        >
        <h2 class="c-section__title">About Me</h2>
      </div>
    </div>
    <div class="o-container">
      <div class="c-pipeline" data-pipeline>
        <p class="c-pipeline__caption">
          <span class="c-pipeline__caption-tag" aria-hidden="true"
            >how_i_work</span
          >
          {siteContent.about.description}
        </p>
        <div class="c-pipeline__track">
          <span class="c-pipeline__terminus c-pipeline__terminus--in"
            >Engineering</span
          >
          <div class="c-pipeline__rail">
            <ul class="c-pipeline__nodes" role="tablist" aria-label="What I do">
              {
                siteContent.about.highlights.map((highlight, i) => (
                  <li class="c-pipeline__node-item" role="presentation">
                    <button
                      type="button"
                      class:list={[
                        'c-pipeline__node',
                        { 'is-active': i === 0 },
                      ]}
                      role="tab"
                      id={`pipe-tab-${i}`}
                      aria-controls={`pipe-panel-${i}`}
                      aria-selected={i === 0 ? 'true' : 'false'}
                      tabindex={i === 0 ? 0 : -1}
                      data-pipeline-node={i}
                    >
                      <span class="c-pipeline__node-dot" aria-hidden="true" />
                      <span class="c-pipeline__node-index" aria-hidden="true">
                        {String(i + 1).padStart(2, '0')}
                      </span>
                      <span class="c-pipeline__node-icon" aria-hidden="true">
                        <Icon name={highlight.icon} />
                      </span>
                      <span class="c-pipeline__node-title">
                        {highlight.title}
                      </span>
                    </button>
                  </li>
                ))
              }
            </ul>
          </div>
          <span class="c-pipeline__terminus c-pipeline__terminus--out"
            >Marketing</span
          >
        </div>
        <div class="c-pipeline__detail">
          {
            siteContent.about.highlights.map((highlight, i) => (
              <div
                class="c-pipeline__detail-item"
                role="tabpanel"
                id={`pipe-panel-${i}`}
                aria-labelledby={`pipe-tab-${i}`}
                tabindex="0"
                hidden={i !== 0}
                data-pipeline-panel={i}
              >
                <p class="c-pipeline__detail-text">{highlight.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Logo Bar Section -->
  <section id="logos" class="c-logo-bar">
    <div class="c-logo-bar__wrapper">
      <div class="c-logo-bar__bar">
        <div class="c-logo-bar__label">Experience With</div>
        <div class="c-logo-bar__set">
          {
            siteContent.clientLogos.map((logo) => (
              <div class="c-logo-bar__item">
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="c-logo-bar__img"
                  loading="lazy"
                  decoding="async"
                  width="150"
                  height="40"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Expertise</span></span
        >
        <h2 class="c-section__title">Skills & Expertise</h2>
      </div>
    </div>
    <div class="o-container">
      <div class="c-capabilities">
        <div class="c-capability c-capability--feature">
          <div class="c-capability__lead">
            <span class="c-capability__tag"
              >{siteContent.skills.feature.tag}</span
            >
            <p class="c-capability__thesis">
              {
                siteContent.skills.feature.thesis.map((segment) =>
                  segment.emphasis ? <b>{segment.text}</b> : segment.text,
                )
              }
            </p>
            {
              /* Distiller: blurred Engineering complexity is pulled into focus,
               distilled to one clear strategy (the clarity node), then assembled
               segment-by-segment into a marketing campaign that goes live.
               Decorative; the animation (skills.css, .c-distiller__*) runs once
               the section scrolls into view. These SVG coordinates are referenced
               by that animation's keyframe offsets — keep them in sync. */
            }
            <div class="c-distiller" aria-hidden="true">
              <svg
                class="c-distiller__svg"
                viewBox="0 0 320 60"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <g class="c-distiller__bars">
                  <rect x="0" y="8" width="4" height="44" rx="1"></rect>
                  <rect x="7" y="16" width="4" height="28" rx="1"></rect>
                  <rect x="14" y="4" width="4" height="52" rx="1"></rect>
                  <rect x="21" y="20" width="4" height="20" rx="1"></rect>
                  <rect x="28" y="12" width="4" height="36" rx="1"></rect>
                  <rect x="35" y="22" width="4" height="16" rx="1"></rect>
                  <rect x="42" y="10" width="4" height="40" rx="1"></rect>
                  <rect x="49" y="18" width="4" height="24" rx="1"></rect>
                </g>
                <rect
                  class="c-distiller__scan"
                  x="0"
                  y="2"
                  width="2.5"
                  height="56"
                  rx="1.25"></rect>
                <path
                  class="c-distiller__lead"
                  d="M56 30 L132 30"
                  stroke-width="2.5"></path>
                <circle class="c-distiller__halo" cx="138" cy="30" r="8"
                ></circle>
                <circle class="c-distiller__node" cx="138" cy="30" r="4.5"
                ></circle>
                <circle class="c-distiller__ring" cx="138" cy="30" r="4.5"
                ></circle>
                <path
                  class="c-distiller__branch"
                  d="M144 30 L176 30"
                  stroke-width="1.5"></path>
                <rect
                  class="c-distiller__frame"
                  x="180"
                  y="21"
                  width="116"
                  height="18"
                  rx="4.5"
                  stroke-width="1.4"></rect>
                <rect
                  class="c-distiller__seg"
                  x="184"
                  y="25"
                  width="25"
                  height="10"
                  rx="2"></rect>
                <rect
                  class="c-distiller__seg c-distiller__seg--2"
                  x="211"
                  y="25"
                  width="25"
                  height="10"
                  rx="2"></rect>
                <rect
                  class="c-distiller__seg c-distiller__seg--3"
                  x="238"
                  y="25"
                  width="25"
                  height="10"
                  rx="2"></rect>
                <rect
                  class="c-distiller__seg c-distiller__seg--4"
                  x="265"
                  y="25"
                  width="25"
                  height="10"
                  rx="2"></rect>
              </svg>
              <div class="c-distiller__ends">
                <span class="c-distiller__end c-distiller__end--in"
                  >{siteContent.skills.feature.distiller.inputLabel}</span
                >
                <span class="c-distiller__end c-distiller__end--out"
                  >{siteContent.skills.feature.distiller.outputLabel}</span
                >
              </div>
            </div>
          </div>
          <div class="c-capability__meta">
            <ul class="c-capability__stats">
              {
                siteContent.skills.feature.stats.map((stat) => (
                  <li class="c-capability__stat">
                    <span class="c-capability__stat-value">{stat.value}</span>
                    <span class="c-capability__stat-label">{stat.label}</span>
                  </li>
                ))
              }
            </ul>
            <a
              class="c-capability__cta"
              href={siteContent.skills.feature.cta.href}
            >
              {siteContent.skills.feature.cta.label}
            </a>
          </div>
        </div>

        {
          /* Discipline + tool cards. On mobile these collapse into an
             accordion (native <details>); on desktop CSS force-opens every
             panel so the bento reads as static cards. First discipline opens
             by default. */
        }
        {
          siteContent.skills.disciplines.map((discipline, i) => (
            <details
              class="c-capability c-capability--collapsible"
              open={i === 0}
            >
              <summary class="c-capability__summary">
                <span class="c-capability__topline">
                  <span class="c-capability__dot" aria-hidden="true" />
                  <span class="c-capability__index">
                    <b>{String(i + 1).padStart(2, '0')}</b>
                    <span class="c-capability__slug"> · {discipline.slug}</span>
                  </span>
                </span>
                <span class="c-capability__name">{discipline.name}</span>
                <span class="c-capability__chev" aria-hidden="true" />
              </summary>
              <div class="c-capability__panel">
                <p class="c-capability__skills">
                  {discipline.skills.join(', ')}.
                </p>
                <div class="c-capability__foot">
                  <span class="c-capability__note">{discipline.note}</span>
                </div>
              </div>
            </details>
          ))
        }

        <details
          class="c-capability c-capability--tools c-capability--collapsible"
        >
          <summary class="c-capability__summary">
            <span class="c-capability__topline">
              <span class="c-capability__dot" aria-hidden="true"></span>
              <span class="c-capability__index">
                <b>
                  {
                    String(siteContent.skills.disciplines.length + 1).padStart(
                      2,
                      '0',
                    )
                  }
                </b>
                <span class="c-capability__slug">
                  {' '}
                  · {siteContent.skills.tools.slug}
                </span>
              </span>
            </span>
            <span class="c-capability__name">
              {siteContent.skills.tools.name}
            </span>
            <span class="c-capability__chev" aria-hidden="true"></span>
          </summary>
          <div class="c-capability__panel">
            <ul class="c-capability__chips">
              {
                siteContent.skills.tools.items.map((item) => (
                  <li class="c-capability__chip">{item}</li>
                ))
              }
            </ul>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Services</span></span
        >
        <h2 class="c-section__title">You Build It. I'll Bring the Party</h2>
      </div>
    </div>
    <div class="o-container">
      <div class="c-engagements">
        <span class="c-engagements__tag">{siteContent.services.tag}</span>
        <p class="c-engagements__lede">{siteContent.services.lede}</p>
        <ul class="c-engagements__list">
          {
            siteContent.services.engagements.map((engagement, i) => (
              <li class="c-engagement">
                <div class="c-engagement__main">
                  <span class="c-engagement__index">
                    <b>{String(i + 1).padStart(2, '0')}</b> · {engagement.slug}
                  </span>
                  <h3 class="c-engagement__name">{engagement.name}</h3>
                  <p class="c-engagement__description">
                    {engagement.description}
                  </p>
                </div>
                <div class="c-engagement__rail">
                  <span class="c-engagement__meta">{engagement.meta}</span>
                  <a
                    class="c-engagement__cta"
                    href={siteContent.services.ctaHref}
                  >
                    {siteContent.services.ctaLabel}
                  </a>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Testimonials</span></span
        >
        <h2 class="c-section__title">I Didn't Even Have to Bribe Them</h2>
      </div>
    </div>
    <div class="o-container">
      <div class="c-testimonials-controls">
        <button
          type="button"
          class="c-btn c-btn--outline c-testimonials-controls__pause-button"
          aria-pressed="false"
          aria-controls="testimonials-container"
          data-testimonials-pause
        >
          <span class="c-testimonials-controls__label--pause"
            >Pause testimonials</span
          >
          <span class="c-testimonials-controls__label--resume"
            >Resume testimonials</span
          >
        </button>
      </div>
      <div id="testimonials-container" class="c-testimonials-scroller">
        {
          testimonialColumns.map((column) => (
            <div class="c-testimonials-scroller__column">
              <div class="c-testimonials-scroller__inner">
                {column.map((testimonial) => (
                  <div class="c-testimonial">
                    <div class="c-testimonial__header">
                      <span class="c-testimonial__avatar" aria-hidden="true">
                        {testimonial.name
                          .split(' ')
                          .map((part) => part[0])
                          .slice(0, 2)
                          .join('')}
                      </span>
                      <div class="c-testimonial__author-info">
                        <p class="c-testimonial__author">{testimonial.name}</p>
                        <p class="c-testimonial__title">
                          {testimonial.title}, {testimonial.company}
                        </p>
                      </div>
                    </div>
                    <p class="c-testimonial__quote">
                      &ldquo;{testimonial.quote}&rdquo;
                    </p>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section id="portfolio" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Selected Work</span></span
        >
        <h2 class="c-section__title">Spoiler Alert: It Went Well</h2>
      </div>
    </div>
    <div class="o-container">
      <!-- Featured: horizontal scroll-snap filmstrip of flagship spotlights -->
      <div
        class="c-featured"
        data-featured
        role="region"
        aria-roledescription="carousel"
        aria-label="Featured work"
      >
        <div
          class="c-featured__viewport"
          data-featured-slides
          tabindex="0"
          aria-label="Featured work — scroll horizontally"
        >
          {
            featuredCampaigns.map((campaign, si) => {
              const alt = campaign.screenshotAlt ?? campaign.name;
              return (
                <article
                  class="c-spotlight c-featured__slide"
                  data-featured-slide
                  role="group"
                  aria-roledescription="slide"
                  aria-label={`${si + 1} of ${featuredCampaigns.length}: ${campaign.name}`}
                >
                  <button
                    type="button"
                    class="c-work-card__media c-spotlight__media"
                    data-work-screenshot={campaign.screenshot}
                    data-work-alt={alt}
                    data-work-title={campaign.name}
                    data-work-campaign={`${campaign.industry} · ${campaign.year}`}
                    aria-label={`Enlarge visual for ${campaign.name}`}
                  >
                    <img
                      class="c-work-card__img"
                      src={campaign.screenshot}
                      alt={alt}
                      loading="lazy"
                      decoding="async"
                      draggable="false"
                      width="1200"
                      height="750"
                    />
                  </button>
                  <div class="c-spotlight__body">
                    <div class="c-spotlight__chips">
                      <span class="c-tag c-tag--accent">
                        {campaign.industry}
                      </span>
                      <span class="c-tag">{campaign.year}</span>
                    </div>
                    <h3 class="c-spotlight__title">{campaign.name}</h3>
                    <p class="c-spotlight__blurb">{campaign.blurb}</p>
                    <div class="c-spotlight__links">
                      {campaign.items.map((item) => {
                        const meta = workTypeMeta[item.type] ?? {};
                        return item.access === 'live' && item.url ? (
                          <a
                            class="c-spotlight__link"
                            href={item.url}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            <Icon name={meta.icon} />
                            <span>{item.title}</span>
                            <Icon name="external-link" />
                          </a>
                        ) : (
                          <span class="c-spotlight__link c-spotlight__link--gated">
                            <Icon name="lock" />
                            <span>{item.title}</span>
                          </span>
                        );
                      })}
                    </div>
                  </div>
                </article>
              );
            })
          }
        </div>
        <div class="c-featured__controls">
          <button
            type="button"
            class="c-featured__btn"
            data-featured-prev
            aria-label="Previous featured item"
          >
            <Icon name="chevron-left" />
          </button>
          <div class="c-featured__dots">
            {
              featuredCampaigns.map((campaign, di) => (
                <button
                  type="button"
                  class:list={['c-featured__dot', { 'is-active': di === 0 }]}
                  data-featured-dot
                  aria-label={`Show ${campaign.name}`}
                  aria-current={di === 0 ? 'true' : 'false'}
                >
                  <span class="c-featured__dot-mark" aria-hidden="true" />
                </button>
              ))
            }
          </div>
          <button
            type="button"
            class="c-featured__btn"
            data-featured-next
            aria-label="Next featured item"
          >
            <Icon name="chevron-right" />
          </button>
          <span
            class="u-sr-only"
            data-featured-status
            role="status"
            aria-live="off"></span>
        </div>
      </div>

      <!-- Archive: full body of work -->
      <div class="c-archive" data-archive>
        <div class="c-archive__head">
          <div class="c-archive__heading-group">
            <h3 class="c-archive__heading">Full body of work</h3>
            <span
              class="c-archive__count"
              data-archive-status
              role="status"
              aria-live="polite"
            >
              {workArchive.length} pieces
            </span>
          </div>
        </div>

        <!-- Asset-type chip-tabs (single-select) -->
        <div
          class="c-archive__tabs"
          role="group"
          aria-label="Filter work by type"
        >
          {
            assetTypes.map((t) => (
              <button
                type="button"
                class:list={[
                  'c-archive__tab',
                  { 'is-active': t.assetType === firstType },
                ]}
                data-type-tab={t.assetType}
                aria-pressed={t.assetType === firstType ? 'true' : 'false'}
              >
                {assetTypeLabels[t.assetType] ?? t.assetType}
                <span class="c-archive__tab-count" data-tab-count>
                  {t.count}
                </span>
              </button>
            ))
          }
        </div>

        <!-- Industry sub-filter -->
        <div
          class="c-archive__filters"
          role="group"
          aria-label="Filter work by industry"
        >
          <button
            type="button"
            class="c-archive__filter is-active"
            data-industry-filter="all"
            aria-pressed="true"
          >
            All
          </button>
          {
            archiveIndustries.map((industry) => (
              <button
                type="button"
                class="c-archive__filter"
                data-industry-filter={industry}
                aria-pressed="false"
              >
                {industry}
              </button>
            ))
          }
        </div>

        <ul class="c-archive__list" data-archive-list>
          {
            archiveRows.map((row) => {
              const sm = workStatusMeta[row.status] ?? {};
              const linkable = archiveHasLink(row.status) && row.url;
              const Wrapper = linkable ? 'a' : 'div';
              const wrapperProps = linkable
                ? {
                    href: row.url,
                    target: '_blank',
                    rel: 'noopener noreferrer',
                  }
                : {};
              return (
                <li
                  class="c-archive__row"
                  data-archive-row
                  data-asset-type={row.assetType}
                  data-industry={row.industry}
                  hidden={row.assetType !== firstType}
                >
                  <Wrapper
                    class={`c-archive__row-link${linkable ? '' : ' c-archive__row-link--static'}`}
                    {...wrapperProps}
                  >
                    <span class="c-archive__row-main">
                      <span class="c-archive__row-head">
                        <span class="c-archive__row-title">{row.title}</span>
                        {row.interview && (
                          <span class="c-archive__tag">Interview</span>
                        )}
                      </span>
                      <span class="c-archive__row-meta">{row.campaign}</span>
                    </span>
                    <span class:list={['c-status', `c-status--${sm.tone}`]}>
                      <Icon name={sm.icon} />
                      {sm.label}
                    </span>
                  </Wrapper>
                </li>
              );
            })
          }
        </ul>
        <div class="c-archive__more-wrap">
          <button
            type="button"
            class="c-btn c-btn--outline"
            data-archive-more
            hidden></button>
        </div>
        <p class="c-archive__empty" data-archive-empty hidden>
          No pieces match this filter.
        </p>
      </div>
    </div>
  </section>

  <dialog class="c-lightbox" data-lightbox aria-label="Work excerpt">
    <figure class="c-lightbox__figure">
      <button
        type="button"
        class="c-lightbox__close"
        data-lightbox-close
        aria-label="Close excerpt"
      >
        <Icon name="x" />
      </button>
      <img class="c-lightbox__img" data-lightbox-img src="" alt="" />
      <figcaption class="c-lightbox__caption">
        <span class="c-lightbox__title" data-lightbox-title></span>
        <span class="c-lightbox__campaign" data-lightbox-campaign></span>
      </figcaption>
    </figure>
  </dialog>

  <!-- Experience Section -->
  <section id="experience" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Experience</span></span
        >
        <h2 class="c-section__title">Experience</h2>
      </div>
    </div>
    <div class="o-container">
      <div id="gantt-chart-container">
        <div class="c-gantt__timeline">
          {ganttYears.map((year) => <span>{year}</span>)}
        </div>
        {
          jobs.map((job, index) => {
            const offset =
              ((job.startDate.getTime() - firstDate.getTime()) /
                totalDuration) *
              100;
            const width =
              ((job.endDate.getTime() - job.startDate.getTime()) /
                totalDuration) *
              100;
            const durationText = getGanttDurationText(
              job.startDate,
              job.endDate,
            );
            const delay = index * 100; // ms, staggers the bar reveal
            const isPresent = job.period.toLowerCase().includes('present');

            return (
              <div class="c-gantt__row">
                <div class="c-gantt__label">
                  <h3>{job.title}</h3>
                  <p>{job.company}</p>
                  <div class="c-gantt__meta">
                    <span class="c-gantt__period">{job.period}</span>
                    <span class="c-gantt__duration">{durationText}</span>
                  </div>
                </div>
                <div
                  class="c-gantt__bar-area"
                  tabindex="0"
                  role="button"
                  aria-expanded="false"
                  aria-label={`Show details for ${job.title} at ${job.company}`}
                >
                  <div
                    class={`c-gantt__bar ${isPresent ? 'is-present' : ''}`}
                    style={`margin-left:${offset.toFixed(2)}%;width:${width.toFixed(2)}%;--anim-delay:${delay}ms`}
                  />
                  <div class="c-gantt__tooltip">
                    <div class="c-gantt__tooltip-period">{job.period}</div>
                    <ul class="c-gantt__tooltip-achievements">
                      {job.achievements.map((a) => (
                        <li>
                          <span
                            class="c-gantt__achievement-icon"
                            aria-hidden="true"
                          >
                            <Icon name={a.icon} />
                          </span>
                          <span set:html={a.text} />
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <slot name="blog-section" />

  <!-- Contact Section -->
  <section id="contact" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Contact</span></span
        >
        <h2 class="c-section__title">Let's Work Together</h2>
      </div>
    </div>
    <div class="o-container">
      <!-- Booking CTA Block -->
      <div class="c-booking-cta" id="schedule" data-calendly-booking>
        <div class="c-booking-cta__bar">
          <div class="c-booking-cta__message">
            <span
              class="c-availability-dot c-booking-cta__dot"
              aria-hidden="true"></span>
            <span>{profile.bookingCta.text}</span>
          </div>
          <a
            class="c-btn c-btn--primary c-booking-cta__button"
            href={profile.bookingCta.url}
            target="_blank"
            rel="noopener"
            data-calendly-open
            aria-expanded="false"
            aria-controls="calendly-booking-panel"
            aria-label={profile.bookingCta.buttonLabel}
          >
            <span class="c-booking-cta__labels" aria-hidden="true">
              <span class="c-booking-cta__label c-booking-cta__label--open"
                >{profile.bookingCta.buttonLabel}</span
              >
              <span class="c-booking-cta__label c-booking-cta__label--close"
                >{profile.bookingCta.closeLabel}</span
              >
            </span>
          </a>
        </div>
        <div class="c-calendly-panel" id="calendly-booking-panel" hidden>
          <div class="c-calendly-panel__inner">
            <div class="c-calendly-panel__header">
              <div>
                <h3 class="c-calendly-panel__title">
                  {profile.bookingCta.expandedTitle}
                </h3>
                <p class="c-calendly-panel__helper">
                  {profile.bookingCta.helperText}
                </p>
              </div>
            </div>
            <div class="c-calendly-panel__booked" data-calendly-booked hidden>
              {profile.bookingCta.bookedText}
            </div>
            <div class="c-calendly-panel__stage">
              <div class="c-calendly-panel__loading" data-calendly-loading>
                <span class="c-calendly-panel__loading-dot" aria-hidden="true"
                ></span>
                <span class="c-calendly-panel__loading-label">
                  {profile.bookingCta.loadingText}
                </span>
              </div>
              <div class="c-calendly-panel__host" data-calendly-container></div>
            </div>
          </div>
        </div>
      </div>
      <div class="c-contact__content">
        <div class="c-contact__info">
          <h3>Get In Touch</h3>
          <p>
            Ready to elevate your technical marketing? Let's discuss how I can
            help drive growth for your B2B or B2C business.
          </p>
          <div class="c-contact__details">
            <div class="c-contact__item">
              <div class="c-contact__icon" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="1em"
                  height="1em"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                  ></path>
                </svg>
              </div>
              <div class="c-contact__text" id="contact-email">
                <span class="u-sr-only">Email: </span>jerry@placeholder.com
              </div>
            </div>

            <div class="c-contact__item">
              <div class="c-contact__icon" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="1em"
                  height="1em"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-10h3v10zm-1.5-11.268c-.966 0-1.75-.784-1.75-1.75s.784-1.75 1.75-1.75 1.75.784 1.75 1.75-.784 1.75-1.75 1.75zm13.5 11.268h-3v-5.604c0-1.337-.026-3.063-1.868-3.063-1.868 0-2.154 1.459-2.154 2.967v5.7h-3v-10h2.881v1.367h.041c.401-.761 1.379-1.563 2.838-1.563 3.036 0 3.599 2 3.599 4.594v5.602z"
                  ></path>
                </svg>
              </div>
              <div class="c-contact__text">
                <a
                  href={siteContent.contactInfo.linkedin.url}
                  id="contact-linkedin"
                  target="_blank"
                  rel="noopener">{siteContent.contactInfo.linkedin.label}</a
                >
              </div>
            </div>
          </div>
        </div>
        <div class="c-contact__form-container">
          <form
            class="c-contact-form"
            id="contact-form"
            action={siteContent.contactForm.endpoint}
            method="POST"
          >
            <input
              type="hidden"
              name="access_key"
              value={siteContent.contactForm.accessKey}
            />
            <input
              type="hidden"
              name="subject"
              value={siteContent.contactForm.subject}
            />
            <div class="c-form-group">
              <label for="name" class="c-form-label">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                class="c-form-control"
                required
              />
            </div>
            <div class="c-form-group">
              <label for="email" class="c-form-label">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="c-form-control"
                required
              />
            </div>
            <div class="c-form-group">
              <label for="company" class="c-form-label">Company</label>
              <input
                type="text"
                id="company"
                name="company"
                class="c-form-control"
              />
            </div>
            <div class="c-form-group">
              <label for="message" class="c-form-label">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="c-form-control"
                required></textarea>
            </div>

            <!-- Frictionless Spam Protection -->
            <input type="checkbox" name="botcheck" class="u-hidden" />

            <button type="submit" class="c-btn c-btn--primary c-btn--full-width"
              >Send Message</button
            >
          </form>
        </div>
      </div>
    </div>
  </section>
</main>

<SiteFooter />
