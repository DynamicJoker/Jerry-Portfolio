---
import { siteContent } from '../content.js';
import Icon from './Icon.astro';
import SiteFooter from './SiteFooter.astro';

const profile = siteContent.profile;

// Gantt data: period strings must be 'MM/YYYY - MM/YYYY' (or '- Present').
const jobs = siteContent.experience
  .map((job) => {
    const [startStr, endStr] = job.period.split(' - ');
    const [startMonth, startYear] = startStr.split('/');
    const startDate = new Date(`${startYear}-${startMonth}-01`);
    let endDate =
      endStr.toLowerCase() === 'present'
        ? new Date()
        : new Date(`${endStr.split('/')[1]}-${endStr.split('/')[0]}-01`);
    return { ...job, startDate, endDate };
  })
  .sort((a, b) => a.sortOrder - b.sortOrder);

const firstDate = new Date(Math.min(...jobs.map((j) => j.startDate)));
const lastDate = new Date(Math.max(...jobs.map((j) => j.endDate)));
const totalDuration = lastDate.getTime() - firstDate.getTime();

const ganttYears = [];
for (let y = firstDate.getFullYear(); y <= lastDate.getFullYear(); y++) {
  ganttYears.push(y);
}

function getGanttDurationText(startDate, endDate) {
  const totalMonths = Math.max(
    1,
    (endDate.getFullYear() - startDate.getFullYear()) * 12 +
      endDate.getMonth() -
      startDate.getMonth(),
  );
  const years = Math.floor(totalMonths / 12);
  const months = totalMonths % 12;
  const parts = [];

  if (years > 0) {
    parts.push(`${years} ${years === 1 ? 'yr' : 'yrs'}`);
  }

  if (months > 0 || parts.length === 0) {
    parts.push(`${months} ${months === 1 ? 'mo' : 'mos'}`);
  }

  return parts.join(' ');
}

// Portfolio filters follow the categories present in the data
const categoryLabel = (category) =>
  siteContent.portfolioCategoryLabels?.[category] ?? category.toUpperCase();
const portfolioFilters = [
  { id: 'all', label: 'All' },
  ...[...new Set(siteContent.portfolio.map((item) => item.category))].map(
    (category) => ({ id: category, label: categoryLabel(category) }),
  ),
];

const numColumns = 3;
const testimonialColumns = Array.from({ length: numColumns }, () => []);
siteContent.testimonials.forEach((testimonial, index) => {
  testimonialColumns[index % numColumns].push(testimonial);
});
---

<main id="main-content">
  <!-- Hero Section -->
  <section id="hero" class="c-hero">
    <div class="c-hero__background" aria-hidden="true">
      <div class="c-hero__aurora">
        <span class="c-hero__aurora-bloom c-hero__aurora-bloom--1"></span>
        <span class="c-hero__aurora-bloom c-hero__aurora-bloom--2"></span>
        <span class="c-hero__aurora-bloom c-hero__aurora-bloom--3"></span>
      </div>
    </div>
    <div class="c-hero__content">
      <div class="c-neon-frame">
        <div class="c-hero__rings" aria-hidden="true">
          <span class="c-hero__rings-pulse"></span>
          <span class="c-hero__rings-pulse c-hero__rings-pulse--2"></span>
        </div>
        <img
          src={profile.portraitImage}
          alt={profile.portraitAlt}
          class="c-neon-frame__image"
          width="300"
          height="300"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />

        <svg
          class="c-neon-frame__circle-svg"
          viewBox="0 0 102 102"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
        >
          <defs>
            <filter id="neon-glow">
              <feGaussianBlur stdDeviation="1.5" result="coloredBlur"
              ></feGaussianBlur>
              <feMerge>
                <feMergeNode in="coloredBlur"></feMergeNode>
                <feMergeNode in="SourceGraphic"></feMergeNode>
              </feMerge>
            </filter>
          </defs>
          <circle class="c-neon-frame__circle" cx="51" cy="51" r="49"></circle>
        </svg>
      </div>
      <div class="c-hero__text">
        <h1 class="c-hero__name">{profile.name}</h1>
        <div class="c-hero__title">
          <span class="c-hero__typing-text" id="typing-text"
            >{profile.jobTitle}</span
          >
        </div>
        <div class="c-hero__stats">
          {
            profile.heroStats.map((stat) => (
              <div class="c-hero__stat">
                <span class="c-hero__stat-value">{stat.value}</span>
                <span class="c-hero__stat-label">{stat.label}</span>
              </div>
            ))
          }
        </div>
        <p class="c-hero__subtitle">
          <span class="c-hero__subtitle-experience">
            <span id="years-experience"
              >{new Date().getFullYear() - profile.experienceStartYear}</span
            >+ Years Experience
          </span>
          <span
            class="c-shape-assembler"
            id="shape-assembler"
            aria-hidden="true"
          >
            <i></i><i></i><i></i>
            <i></i><i></i><i></i>
            <i></i><i></i><i></i>
          </span>
          <a
            class="c-hero__subtitle-location"
            href="#schedule"
            aria-label={`${profile.availability.status}, go to scheduling section`}
          >
            <span>{profile.availability.status}</span>
            <span
              class="c-availability-dot c-hero__subtitle-location-dot"
              aria-hidden="true"></span>
          </a>
        </p>
        <div class="c-hero__buttons">
          <a href="#portfolio" class="c-btn c-btn--primary c-btn--lg"
            >View Portfolio</a
          >
          <a href="#contact" class="c-btn c-btn--outline c-btn--lg"
            >Contact Me</a
          >
        </div>
      </div>
    </div>
    <a
      href="#about"
      class="c-scroll-indicator"
      aria-label="Scroll to next section"
    >
      <div class="c-scroll-indicator__arrow"></div>
    </a>
  </section>

  <!-- About Section -->
  <section id="about" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">About</span></span
        >
        <h2 class="c-section__title">About Me</h2>
      </div>
    </div>
    <div class="o-container">
      <div class="c-about__content">
        <div class="c-about__text">
          <p class="c-about__description">{siteContent.about.description}</p>
          <div class="c-about__highlights">
            {
              siteContent.about.highlights.map((highlight) => (
                <div class="c-highlight" tabindex="0">
                  <div class="c-highlight__header">
                    <div class="c-highlight__icon" aria-hidden="true">
                      <Icon name={highlight.icon} />
                    </div>
                    <h3 class="c-highlight__title">{highlight.title}</h3>
                  </div>
                  <div class="c-highlight__description">
                    <p>{highlight.description}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Logo Bar Section -->
  <section id="logos" class="c-logo-bar">
    <div class="c-logo-bar__wrapper">
      <div class="c-logo-bar__bar">
        <div class="c-logo-bar__label">Experience With</div>
        <div class="c-logo-bar__set">
          {
            siteContent.clientLogos.map((logo) => (
              <div class="c-logo-bar__item">
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="c-logo-bar__img"
                  loading="lazy"
                  decoding="async"
                  width="150"
                  height="40"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Expertise</span></span
        >
        <h2 class="c-section__title">Skills & Expertise</h2>
      </div>
    </div>
    <div class="o-container">
      <div class="c-skills-grid" id="skills-grid">
        {
          siteContent.skills.map((category) => (
            <div class="c-skill-category">
              <h3 class="c-skill-category__title">{category.category}</h3>
              {category.type === 'pane' ? (
                <div
                  class="c-skill-category__pane"
                  tabindex="0"
                  role="region"
                  aria-label={`${category.category} skills`}
                >
                  <div class="c-skill-category__tags">
                    {category.tags.map((tagText) => (
                      <span class="c-skill-category__tag">{tagText}</span>
                    ))}
                  </div>
                </div>
              ) : (
                <div class="c-skill-category__tags">
                  <div>
                    {category.tags.map((tagText) => (
                      <span class="c-skill-category__tag">{tagText}</span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Services</span></span
        >
        <h2 class="c-section__title">You Build It. I'll Bring the Party</h2>
      </div>
    </div>
    <div class="o-container">
      <div class="c-services-grid" id="services-grid">
        {
          siteContent.services.map((service) => (
            <div class="c-service-card">
              <div class="c-service-card__icon" aria-hidden="true">
                <Icon name={service.icon} />
              </div>
              <h3 class="c-service-card__title">{service.title}</h3>
              <p class="c-service-card__description">{service.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Testimonials</span></span
        >
        <h2 class="c-section__title">I Didn't Even Have to Bribe Them</h2>
      </div>
    </div>
    <div class="o-container">
      <div class="c-testimonials-controls">
        <button
          type="button"
          class="c-btn c-btn--outline c-testimonials-controls__pause-button"
          aria-pressed="false"
          aria-controls="testimonials-container"
          data-testimonials-pause
        >
          <span class="c-testimonials-controls__label--pause"
            >Pause testimonials</span
          >
          <span class="c-testimonials-controls__label--resume"
            >Resume testimonials</span
          >
        </button>
      </div>
      <div id="testimonials-container" class="c-testimonials-scroller">
        {
          testimonialColumns.map((column) => (
            <div class="c-testimonials-scroller__column">
              <div class="c-testimonials-scroller__inner">
                {column.map((testimonial) => (
                  <div class="c-testimonial">
                    <div class="c-testimonial__header">
                      <span class="c-testimonial__avatar" aria-hidden="true">
                        {testimonial.name
                          .split(' ')
                          .map((part) => part[0])
                          .slice(0, 2)
                          .join('')}
                      </span>
                      <div class="c-testimonial__author-info">
                        <p class="c-testimonial__author">{testimonial.name}</p>
                        <p class="c-testimonial__title">
                          {testimonial.title}, {testimonial.company}
                        </p>
                      </div>
                    </div>
                    <p class="c-testimonial__quote">
                      &ldquo;{testimonial.quote}&rdquo;
                    </p>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section id="portfolio" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Selected Work</span></span
        >
        <h2 class="c-section__title">Spoiler Alert: It Went Well</h2>
      </div>
    </div>
    <div class="o-container">
      <div
        class="c-portfolio-filters"
        role="group"
        aria-label="Filter portfolio projects"
      >
        {
          portfolioFilters.map((filter) => (
            <button
              type="button"
              class:list={[
                'c-portfolio-filters__btn',
                { 'is-active': filter.id === 'all' },
              ]}
              data-filter={filter.id}
              aria-pressed={filter.id === 'all' ? 'true' : 'false'}
            >
              {filter.label}
            </button>
          ))
        }
      </div>
      <div class="c-portfolio-grid" id="portfolio-grid">
        {
          siteContent.portfolio.map((item) => (
            <div class="c-portfolio-grid__item" data-category={item.category}>
              <div class="c-portfolio-card c-card">
                <div class="c-portfolio-card__header">
                  <h3 class="c-portfolio-card__title">{item.title}</h3>
                  <span class="c-portfolio-card__category">
                    {categoryLabel(item.category)}
                  </span>
                </div>
                <p class="c-portfolio-card__description">{item.description}</p>
                <div class="c-portfolio-card__results">
                  {item.results.map((resultText) => (
                    <div class="c-portfolio-card__result">{resultText}</div>
                  ))}
                </div>
                <div class="c-portfolio-card__tags">
                  {item.tags.map((tagText) => (
                    <span class="c-tag">{tagText}</span>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Experience Section -->
  <section id="experience" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Experience</span></span
        >
        <h2 class="c-section__title">Experience</h2>
      </div>
    </div>
    <div class="o-container">
      <div id="gantt-chart-container">
        <div class="c-gantt__timeline">
          {ganttYears.map((year) => <span>{year}</span>)}
        </div>
        {
          jobs.map((job, index) => {
            const offset =
              ((job.startDate.getTime() - firstDate.getTime()) /
                totalDuration) *
              100;
            const width =
              ((job.endDate.getTime() - job.startDate.getTime()) /
                totalDuration) *
              100;
            const durationText = getGanttDurationText(
              job.startDate,
              job.endDate,
            );
            const delay = index * 100; // ms, staggers the bar reveal
            const isPresent = job.period.toLowerCase().includes('present');

            return (
              <div class="c-gantt__row">
                <div class="c-gantt__label">
                  <h3>{job.title}</h3>
                  <p>{job.company}</p>
                  <div class="c-gantt__meta">
                    <span class="c-gantt__period">{job.period}</span>
                    <span class="c-gantt__duration">{durationText}</span>
                  </div>
                </div>
                <div
                  class="c-gantt__bar-area"
                  tabindex="0"
                  role="button"
                  aria-expanded="false"
                  aria-label={`Show details for ${job.title} at ${job.company}`}
                >
                  <div
                    class={`c-gantt__bar ${isPresent ? 'is-present' : ''}`}
                    style={`margin-left:${offset.toFixed(2)}%;width:${width.toFixed(2)}%;--anim-delay:${delay}ms`}
                  />
                  <div class="c-gantt__tooltip">
                    <div class="c-gantt__tooltip-period">{job.period}</div>
                    <ul class="c-gantt__tooltip-achievements">
                      {job.achievements.map((a) => (
                        <li>
                          <span
                            class="c-gantt__achievement-icon"
                            aria-hidden="true"
                          >
                            <Icon name={a.icon} />
                          </span>
                          <span set:html={a.text} />
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <slot name="blog-section" />

  <!-- Contact Section -->
  <section id="contact" class="c-section">
    <div class="c-section__header">
      <div class="o-container c-section__header-inner">
        <span class="c-section__kicker"
          ><span class="c-section__kicker-label">Contact</span></span
        >
        <h2 class="c-section__title">Let's Work Together</h2>
      </div>
    </div>
    <div class="o-container">
      <!-- Booking CTA Block -->
      <div class="c-booking-cta" id="schedule" data-calendly-booking>
        <div class="c-booking-cta__bar">
          <div class="c-booking-cta__message">
            <span
              class="c-availability-dot c-booking-cta__dot"
              aria-hidden="true"></span>
            <span>{profile.bookingCta.text}</span>
          </div>
          <a
            class="c-btn c-btn--primary c-booking-cta__button"
            href={profile.bookingCta.url}
            target="_blank"
            rel="noopener"
            data-calendly-open
            aria-expanded="false"
            aria-controls="calendly-booking-panel"
            aria-label={profile.bookingCta.buttonLabel}
          >
            <span class="c-booking-cta__labels" aria-hidden="true">
              <span class="c-booking-cta__label c-booking-cta__label--open"
                >{profile.bookingCta.buttonLabel}</span
              >
              <span class="c-booking-cta__label c-booking-cta__label--close"
                >{profile.bookingCta.closeLabel}</span
              >
            </span>
          </a>
        </div>
        <div class="c-calendly-panel" id="calendly-booking-panel" hidden>
          <div class="c-calendly-panel__inner">
            <div class="c-calendly-panel__header">
              <div>
                <h3 class="c-calendly-panel__title">
                  {profile.bookingCta.expandedTitle}
                </h3>
                <p class="c-calendly-panel__helper">
                  {profile.bookingCta.helperText}
                </p>
              </div>
            </div>
            <div class="c-calendly-panel__booked" data-calendly-booked hidden>
              {profile.bookingCta.bookedText}
            </div>
            <div class="c-calendly-panel__loading" data-calendly-loading>
              {profile.bookingCta.loadingText}
            </div>
            <div class="c-calendly-panel__host" data-calendly-container></div>
          </div>
        </div>
      </div>
      <div class="c-contact__content">
        <div class="c-contact__info">
          <h3>Get In Touch</h3>
          <p>
            Ready to elevate your technical marketing? Let's discuss how I can
            help drive growth for your B2B or B2C business.
          </p>
          <div class="c-contact__details">
            <div class="c-contact__item">
              <div class="c-contact__icon" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="1em"
                  height="1em"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                  ></path>
                </svg>
              </div>
              <div class="c-contact__text" id="contact-email">
                <span class="u-sr-only">Email: </span>jerry@placeholder.com
              </div>
            </div>

            <div class="c-contact__item">
              <div class="c-contact__icon" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="1em"
                  height="1em"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-10h3v10zm-1.5-11.268c-.966 0-1.75-.784-1.75-1.75s.784-1.75 1.75-1.75 1.75.784 1.75 1.75-.784 1.75-1.75 1.75zm13.5 11.268h-3v-5.604c0-1.337-.026-3.063-1.868-3.063-1.868 0-2.154 1.459-2.154 2.967v5.7h-3v-10h2.881v1.367h.041c.401-.761 1.379-1.563 2.838-1.563 3.036 0 3.599 2 3.599 4.594v5.602z"
                  ></path>
                </svg>
              </div>
              <div class="c-contact__text">
                <a
                  href={siteContent.contactInfo.linkedin.url}
                  id="contact-linkedin"
                  target="_blank"
                  rel="noopener">{siteContent.contactInfo.linkedin.label}</a
                >
              </div>
            </div>
          </div>
        </div>
        <div class="c-contact__form-container">
          <form
            class="c-contact-form"
            id="contact-form"
            action={siteContent.contactForm.endpoint}
            method="POST"
          >
            <input
              type="hidden"
              name="access_key"
              value={siteContent.contactForm.accessKey}
            />
            <input
              type="hidden"
              name="subject"
              value={siteContent.contactForm.subject}
            />
            <div class="c-form-group">
              <label for="name" class="c-form-label">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                class="c-form-control"
                required
              />
            </div>
            <div class="c-form-group">
              <label for="email" class="c-form-label">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="c-form-control"
                required
              />
            </div>
            <div class="c-form-group">
              <label for="company" class="c-form-label">Company</label>
              <input
                type="text"
                id="company"
                name="company"
                class="c-form-control"
              />
            </div>
            <div class="c-form-group">
              <label for="message" class="c-form-label">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="c-form-control"
                required></textarea>
            </div>

            <!-- Frictionless Spam Protection -->
            <input type="checkbox" name="botcheck" class="u-hidden" />

            <button type="submit" class="c-btn c-btn--primary c-btn--full-width"
              >Send Message</button
            >
          </form>
        </div>
      </div>
    </div>
  </section>
</main>

<SiteFooter />
