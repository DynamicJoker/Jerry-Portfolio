---
const { current = 'home' } = Astro.props;
const prefix = current === 'home' ? '' : '/';

const links = [
  { href: `${prefix}#hero`, label: 'Home', id: 'home' },
  { href: `${prefix}#about`, label: 'About', id: 'about' },
  { href: `${prefix}#skills`, label: 'Skills', id: 'skills' },
  { href: `${prefix}#services`, label: 'Services', id: 'services' },
  { href: `${prefix}#testimonials`, label: 'Testimonials', id: 'testimonials' },
  { href: `${prefix}#portfolio`, label: 'Portfolio', id: 'portfolio' },
  { href: `${prefix}#experience`, label: 'Experience', id: 'experience' },
  { href: current === 'home' ? '#blog' : '/blog/', label: 'Blog', id: 'blog' },
  { href: `${prefix}#contact`, label: 'Contact', id: 'contact' }
];

const currentLabel = links.find((link) => link.id === current)?.label ?? 'Home';
---

<nav class="navbar" id="navbar">
  <div class="nav-container">
    <a href={current === 'home' ? '#hero' : '/'} class="nav-brand" aria-label="Jerry James home">
      <img src="/brand/jj-signal-logo.svg" alt="" class="nav-brand-logo" width="260" height="64" />
    </a>
    <div class="nav-actions">
      <button
        class="nav-current"
        id="nav-current-toggle"
        type="button"
        aria-label={`Open navigation menu, currently ${currentLabel}`}
        aria-controls="nav-menu"
        aria-expanded="false"
      >
        <span class="nav-current-kicker">Viewing</span>
        <span class="nav-current-label" data-current-section>{currentLabel}</span>
      </button>
      <button
        class="hamburger"
        id="hamburger"
        type="button"
        aria-label="Open navigation menu"
        aria-controls="nav-menu"
        aria-expanded="false"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
      <div class="nav-menu" id="nav-menu">
        {
          links.map((link) => (
            <a
              href={link.href}
              class:list={['nav-link', { active: current === link.id }]}
              aria-current={current === link.id ? 'location' : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  (() => {
    if (document.body?.dataset.page === 'home') return;

    const hamburger = document.getElementById('hamburger');
    const currentToggle = document.getElementById('nav-current-toggle');
    const currentLabel = document.querySelector('[data-current-section]');
    const navMenu = document.getElementById('nav-menu');
    const navbar = document.getElementById('navbar');
    const links = document.querySelectorAll('.nav-link');

    if (!hamburger || !navMenu) return;

    const controls = [hamburger, currentToggle].filter(Boolean);

    const setNavOpen = (isOpen) => {
      hamburger.classList.toggle('active', isOpen);
      navMenu.classList.toggle('active', isOpen);
      controls.forEach((control) => {
        control.setAttribute('aria-expanded', String(isOpen));
        control.setAttribute(
          'aria-label',
          `${isOpen ? 'Close' : 'Open'} navigation menu, currently ${currentLabel?.textContent?.trim() || 'Blog'}`
        );
      });
    };

    hamburger.addEventListener('click', () => setNavOpen(!navMenu.classList.contains('active')));
    currentToggle?.addEventListener('click', () => setNavOpen(!navMenu.classList.contains('active')));
    links.forEach((link) => link.addEventListener('click', () => setNavOpen(false)));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && navMenu.classList.contains('active')) {
        setNavOpen(false);
        hamburger.focus();
      }
    });

    const updateScrolled = () => navbar?.classList.toggle('scrolled', window.scrollY > 10);
    updateScrolled();
    window.addEventListener('scroll', updateScrolled, { passive: true });
  })();
</script>
