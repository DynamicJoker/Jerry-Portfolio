---
import BrandLogo from './BrandLogo.astro';

const { current = 'home' } = Astro.props;
const prefix = current === 'home' ? '' : '/';

const links = [
  { href: `${prefix}#hero`, label: 'Home', id: 'home' },
  { href: `${prefix}#about`, label: 'About', id: 'about' },
  { href: `${prefix}#skills`, label: 'Skills', id: 'skills' },
  { href: `${prefix}#services`, label: 'Services', id: 'services' },
  { href: `${prefix}#testimonials`, label: 'Testimonials', id: 'testimonials' },
  { href: `${prefix}#portfolio`, label: 'Portfolio', id: 'portfolio' },
  { href: `${prefix}#experience`, label: 'Experience', id: 'experience' },
  { href: current === 'home' ? '#blog' : '/blog/', label: 'Blog', id: 'blog' },
  { href: `${prefix}#contact`, label: 'Contact', id: 'contact' },
];

const currentLabel = links.find((link) => link.id === current)?.label ?? 'Home';
---

<nav class="navbar" id="navbar" aria-label="Primary">
  <div class="nav-container">
    <a
      href={current === 'home' ? '#hero' : '/'}
      class="nav-brand"
      aria-label="Jerry James home"
    >
      <BrandLogo />
    </a>
    <div class="nav-actions">
      <button
        class="hamburger nav-toggle"
        id="hamburger"
        type="button"
        aria-label={`Open navigation menu, currently ${currentLabel}`}
        aria-controls="nav-menu"
        aria-expanded="false"
      >
        <span class="nav-toggle-label" data-current-section>{currentLabel}</span
        >
        <span class="nav-toggle-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
      <div class="nav-menu" id="nav-menu">
        <div class="nav-rail">
          {
            links.map((link) => (
              <a
                href={link.href}
                class:list={['nav-link', { active: current === link.id }]}
                aria-current={current === link.id ? 'location' : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
      <button
        class="theme-toggle"
        id="theme-toggle"
        type="button"
        aria-label="Toggle color theme"
        hidden
      >
        <span class="theme-toggle__ring" aria-hidden="true"></span>
        <span class="theme-toggle__core" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  /* Theme controller — runs on EVERY page (unlike main.js, which is
     home-only). The pre-paint script in BaseLayout already set the
     attribute; this adds the toggle behavior and system-change tracking. */
  (() => {
    const KEY = 'color-scheme';
    const root = document.documentElement;
    const button = document.getElementById('theme-toggle');
    const media = window.matchMedia('(prefers-color-scheme: dark)');
    const metas = document.querySelectorAll('meta[name="theme-color"]');
    const getStored = () => {
      try {
        return localStorage.getItem(KEY);
      } catch {
        return null;
      }
    };
    const apply = (scheme) => {
      root.dataset.colorScheme = scheme;
      metas.forEach((meta) =>
        meta.setAttribute('content', scheme === 'dark' ? '#0f1117' : '#fafaf9'),
      );
      button?.setAttribute(
        'aria-label',
        scheme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme',
      );
      window.dispatchEvent(
        new CustomEvent('colorschemechange', { detail: { scheme } }),
      );
    };

    apply(root.dataset.colorScheme || (media.matches ? 'dark' : 'light'));

    if (button) {
      button.hidden = false;
      button.addEventListener('click', () => {
        const next = root.dataset.colorScheme === 'dark' ? 'light' : 'dark';
        try {
          localStorage.setItem(KEY, next);
        } catch {
          /* storage blocked: theme still applies for this page view */
        }
        apply(next);
        button.classList.remove('is-pulsing');
        void button.offsetWidth; /* restart the one-shot pulse */
        button.classList.add('is-pulsing');
      });
      button.addEventListener('animationend', () =>
        button.classList.remove('is-pulsing'),
      );
    }

    /* Follow live system changes only while there is no stored preference */
    media.addEventListener('change', (event) => {
      if (getStored()) return;
      apply(event.matches ? 'dark' : 'light');
    });
  })();
</script>

<script is:inline>
  (() => {
    if (document.body?.dataset.page === 'home') return;

    const hamburger = document.getElementById('hamburger');
    const currentLabel = document.querySelector('[data-current-section]');
    const navMenu = document.getElementById('nav-menu');
    const navbar = document.getElementById('navbar');
    const links = document.querySelectorAll('.nav-link');

    if (!hamburger || !navMenu) return;

    const controls = [hamburger].filter(Boolean);
    const navMenuQuery = window.matchMedia('(max-width: 64rem)');

    const setNavOpen = (isOpen) => {
      hamburger.classList.toggle('active', isOpen);
      navMenu.classList.toggle('active', isOpen);
      controls.forEach((control) => {
        control.setAttribute('aria-expanded', String(isOpen));
        control.setAttribute(
          'aria-label',
          `${isOpen ? 'Close' : 'Open'} navigation menu, currently ${currentLabel?.textContent?.trim() || 'Blog'}`,
        );
      });
    };
    const isNavOpen = () => navMenu.classList.contains('active');
    const closeNav = ({ restoreFocus = false } = {}) => {
      if (!isNavOpen()) return;

      setNavOpen(false);
      if (restoreFocus) {
        hamburger.focus();
      }
    };

    hamburger.addEventListener('click', () => setNavOpen(!isNavOpen()));
    links.forEach((link) => link.addEventListener('click', () => closeNav()));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isNavOpen()) {
        closeNav({ restoreFocus: true });
      }
    });
    document.addEventListener(
      'pointerdown',
      (event) => {
        if (!isNavOpen()) return;
        if (hamburger.contains(event.target) || navMenu.contains(event.target))
          return;

        closeNav();
      },
      { passive: true },
    );
    navMenuQuery.addEventListener('change', (event) => {
      if (!event.matches) {
        closeNav();
      }
    });

    const updateScrolled = () =>
      navbar?.classList.toggle('scrolled', window.scrollY > 10);
    updateScrolled();
    window.addEventListener('scroll', updateScrolled, { passive: true });
  })();
</script>
