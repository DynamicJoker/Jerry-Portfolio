---
// Inline brand logo so the wordmark can animate independently of the monogram.
// The monogram ring + J use the blue brand gradient and the orbit "signal"
// arc carries the lighter blue accent; the
// "Jerry James" wordmark sits in its own group so it can fade/slide in when the
// navbar expands past the hero name. Labeling is handled by the parent <a>.
---

<svg
  class="nav-brand-logo"
  height="64"
  viewBox="0 0 260 64"
  fill="none"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient
      id="jj-logo-ring"
      x1="10"
      x2="59"
      y1="11"
      y2="55"
      gradientUnits="userSpaceOnUse"
    >
      <stop stop-color="#90D5FF"></stop>
      <stop offset="1" stop-color="#517891"></stop>
    </linearGradient>
    <linearGradient
      id="jj-logo-orbit"
      x1="8"
      x2="71"
      y1="29"
      y2="35"
      gradientUnits="userSpaceOnUse"
    >
      <stop stop-color="#57B9FF"></stop>
      <stop offset=".5" stop-color="#90D5FF"></stop>
      <stop offset="1" stop-color="#57B9FF"></stop>
    </linearGradient>
    <linearGradient
      id="jj-logo-gloss"
      x1="30"
      x2="40"
      y1="14"
      y2="48"
      gradientUnits="userSpaceOnUse"
    >
      <stop stop-color="#D6EFFF"></stop>
      <stop offset=".45" stop-color="#57B9FF"></stop>
      <stop offset="1" stop-color="#517891"></stop>
    </linearGradient>
    <linearGradient
      id="jj-wordmark"
      x1="87"
      x2="246"
      y1="32"
      y2="32"
      gradientUnits="userSpaceOnUse"
    >
      <stop stop-color="#90D5FF"></stop>
      <stop offset=".45" stop-color="#57B9FF"></stop>
      <stop offset="1" stop-color="#90D5FF"></stop>
    </linearGradient>
    <mask
      id="jj-cut"
      width="70"
      height="64"
      x="0"
      y="0"
      maskUnits="userSpaceOnUse"
    >
      <path fill="#fff" d="M0 0h70v64H0z"></path>
      <path
        stroke="#000"
        stroke-linecap="round"
        stroke-width="3.8"
        d="M6.5 35.6C21 30.8 50 30.8 67 35.6"></path>
    </mask>
  </defs>
  <g>
    <circle
      cx="35"
      cy="32"
      r="23.5"
      fill="#07090c"
      fill-opacity=".72"
      stroke="url(#jj-logo-ring)"
      stroke-width="2.1"></circle>
    <circle
      cx="35"
      cy="32"
      r="18.6"
      stroke="#f8fcff"
      stroke-opacity=".12"
      stroke-width=".9"></circle>
    <path
      fill="url(#jj-logo-gloss)"
      d="M41.2 18.07V37.3q0 1.93-.61 3.53-.61 1.59-1.79 2.73-1.17 1.13-2.92 1.75-1.74.62-4.05.62-1.7 0-3.27-.4-1.58-.4-2.76-1.01v-4.99q.53.44 1.23.82.71.37 1.5.66.8.28 1.64.44t1.66.16q.69 0 1.44-.26.74-.25 1.33-.84.59-.58.97-1.54.38-.95.38-2.36V22.33h-9.94v-4.26"
      mask="url(#jj-cut)"></path>
  </g>
  <path
    stroke="url(#jj-logo-orbit)"
    stroke-linecap="round"
    stroke-width="1.7"
    d="M6.5 35.6C21 30.8 50 30.8 67 35.6"></path>
  <g class="nav-brand-wordmark">
    <!-- Live text (not outlines) so it always renders in the site's display
         font. textLength pins the run to the same 87->246 span the gradient
         was calibrated for, regardless of font metrics. -->
    <text
      class="nav-brand-wordmark-text"
      x="87"
      y="40"
      textLength="159"
      lengthAdjust="spacing"
      fill="url(#jj-wordmark)">JERRY JAMES</text
    >
  </g>
</svg>
