---
// Inline brand logo so the wordmark can animate independently of the monogram.
// The monogram ring + J use the indigo brand gradient and the orbit "signal"
// arc carries the single amber accent; the
// "Jerry James" wordmark sits in its own group so it can fade/slide in when the
// navbar expands past the hero name. Labeling is handled by the parent <a>.
---

<svg
  class="nav-brand-logo"
  height="64"
  viewBox="0 0 260 64"
  fill="none"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient
      id="jj-logo-ring"
      x1="10"
      x2="59"
      y1="11"
      y2="55"
      gradientUnits="userSpaceOnUse"
    >
      <stop stop-color="#818CF8"></stop>
      <stop offset="1" stop-color="#4338CA"></stop>
    </linearGradient>
    <linearGradient
      id="jj-logo-orbit"
      x1="8"
      x2="71"
      y1="29"
      y2="35"
      gradientUnits="userSpaceOnUse"
    >
      <stop stop-color="#F59E0B"></stop>
      <stop offset=".5" stop-color="#FBBF24"></stop>
      <stop offset="1" stop-color="#F59E0B"></stop>
    </linearGradient>
    <linearGradient
      id="jj-logo-gloss"
      x1="30"
      x2="40"
      y1="14"
      y2="48"
      gradientUnits="userSpaceOnUse"
    >
      <stop stop-color="#E0E7FF"></stop>
      <stop offset=".45" stop-color="#818CF8"></stop>
      <stop offset="1" stop-color="#4338CA"></stop>
    </linearGradient>
    <linearGradient
      id="jj-wordmark"
      x1="87"
      x2="246"
      y1="32"
      y2="32"
      gradientUnits="userSpaceOnUse"
    >
      <stop stop-color="#818CF8"></stop>
      <stop offset=".45" stop-color="#6366F1"></stop>
      <stop offset="1" stop-color="#FBBF24"></stop>
    </linearGradient>
    <mask
      id="jj-cut"
      width="70"
      height="64"
      x="0"
      y="0"
      maskUnits="userSpaceOnUse"
    >
      <path fill="#fff" d="M0 0h70v64H0z"></path>
      <path
        stroke="#000"
        stroke-linecap="round"
        stroke-width="3.8"
        d="M6.5 35.6C21 30.8 50 30.8 67 35.6"></path>
    </mask>
  </defs>
  <g>
    <circle
      cx="35"
      cy="32"
      r="23.5"
      fill="#07090c"
      fill-opacity=".72"
      stroke="url(#jj-logo-ring)"
      stroke-width="2.1"></circle>
    <circle
      cx="35"
      cy="32"
      r="18.6"
      stroke="#f8fcff"
      stroke-opacity=".12"
      stroke-width=".9"></circle>
    <path
      fill="url(#jj-logo-gloss)"
      d="M41.2 18.07V37.3q0 1.93-.61 3.53-.61 1.59-1.79 2.73-1.17 1.13-2.92 1.75-1.74.62-4.05.62-1.7 0-3.27-.4-1.58-.4-2.76-1.01v-4.99q.53.44 1.23.82.71.37 1.5.66.8.28 1.64.44t1.66.16q.69 0 1.44-.26.74-.25 1.33-.84.59-.58.97-1.54.38-.95.38-2.36V22.33h-9.94v-4.26"
      mask="url(#jj-cut)"></path>
  </g>
  <path
    stroke="url(#jj-logo-orbit)"
    stroke-linecap="round"
    stroke-width="1.7"
    d="M6.5 35.6C21 30.8 50 30.8 67 35.6"></path>
  <g class="nav-brand-wordmark">
    <path
      fill="url(#jj-wordmark)"
      d="M92.84 40.36q-1.73 0-2.99-.75-1.26-.76-1.93-2.1-.66-1.34-.68-3.04l2.95-.16q.04 1.75.73 2.63.68.88 1.92.88 1.26 0 1.96-.89t.7-2.62V24.02h2.92v10.29q0 1.84-.7 3.2-.69 1.37-1.94 2.11t-2.94.74m20.18-.36h-10.94V24.02h10.76v2.55h-7.83v4.16h7.56v2.52h-7.56v4.21h8.01zm6.22 0h-2.92V24.02H123q1.73 0 2.99.59t1.96 1.66q.7 1.09.7 2.55 0 1.1-.47 1.95-.48.86-1.26 1.38-.48.31-1.01.47.92.14 1.53.63.83.7.94 2.14l.4 4.61h-2.97l-.33-4.19q-.07-.94-.61-1.39t-1.8-.45h-3.83zm0-13.43v4.84h3.58q1.33 0 2.07-.64.74-.63.74-1.77 0-1.17-.75-1.8t-2.19-.63zM135.15 40h-2.93V24.02h6.68q1.74 0 3 .59t1.95 1.66q.7 1.09.7 2.55 0 1.1-.47 1.95-.47.86-1.26 1.38-.47.31-1.01.47.92.14 1.53.63.83.7.94 2.14l.41 4.61h-2.97l-.34-4.19q-.07-.94-.61-1.39t-1.8-.45h-3.82zm0-13.43v4.84h3.57q1.33 0 2.07-.64.75-.63.75-1.77 0-1.17-.76-1.8-.75-.63-2.19-.63zM154.69 40h-2.94v-6.3l-5.58-9.68h3.28l3.78 6.8 3.76-6.8h3.28l-5.58 9.68zm18.38.36q-1.74 0-3-.75-1.26-.76-1.92-2.1t-.68-3.04l2.94-.16q.05 1.75.73 2.63.69.88 1.93.88 1.26 0 1.95-.89.7-.89.7-2.62V24.02h2.93v10.29q0 1.84-.7 3.2-.7 1.37-1.95 2.11t-2.93.74M184 40h-3.06l5.76-15.98h3.57L196.03 40h-3.06l-1.32-3.78h-6.33zm4.5-13.03-2.32 6.75h4.61zM201.59 40h-2.93V24.02h3.94l4.41 12.38 4.41-12.38h3.94V40h-2.93V28.98l-4.03 11h-2.79l-4.02-11zm28.7 0h-10.93V24.02h10.75v2.55h-7.83v4.16h7.56v2.52h-7.56v4.21h8.01zm9.34.36q-1.99 0-3.43-.7-1.44-.69-2.26-1.94t-.95-2.92l2.97-.18q.13 1.04.59 1.76t1.24 1.09 1.88.37q.94 0 1.61-.24.66-.23 1.01-.69t.35-1.14q0-.61-.29-1.09-.3-.48-1.13-.88-.83-.39-2.47-.78-1.98-.44-3.18-1.02-1.19-.57-1.73-1.44-.54-.86-.54-2.17 0-1.39.7-2.46t1.98-1.67 3.08-.6q1.91 0 3.24.69t2.09 1.88q.77 1.19.95 2.75l-2.95.13q-.11-.88-.53-1.53-.41-.65-1.12-1.02t-1.72-.37q-1.26 0-1.99.57-.74.57-.74 1.52 0 .65.31 1.08.3.43 1.09.73t2.2.64q2.14.45 3.4 1.15t1.8 1.62.54 2.11q0 1.47-.74 2.53-.74 1.07-2.09 1.65-1.35.57-3.17.57"
    ></path>
  </g>
</svg>
