---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<section id="blog" class="c-section c-home-blog">
  <div class="c-section__header">
    <div class="o-container c-section__header-inner">
      <span class="c-section__kicker"
        ><span class="c-section__kicker-label">Writing</span></span
      >
      <h2 class="c-section__title">Field Notes From the Content Lab</h2>
    </div>
  </div>
  <div class="o-container">
    <div class="c-home-blog__feature">
      <div class="c-home-blog__image">
        <img
          src="/images/blog/blog-cover.svg"
          alt="Abstract illustration of tangled technical lines passing through a lens and emerging as clean, ordered content with a rising trend line"
          loading="lazy"
          decoding="async"
          width="1600"
          height="900"
        />
      </div>
      <div class="c-home-blog__copy">
        <p class="c-blog-kicker">Blog</p>
        <h3>
          Useful thinking for technical marketers, founders, and product teams.
        </h3>
        <p>
          Notes on turning complex technology into clearer positioning, sharper
          content systems, and pages that help buyers understand what matters.
        </p>
        <a href="/blog/" class="c-btn c-btn--primary">View all posts</a>
      </div>
    </div>

    {
      posts.length > 0 ? (
        <div class="c-home-blog__grid">
          {posts.map((post) => (
            <article class="c-home-blog__card">
              <div class="c-home-blog__card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.tags[0] && <span>{post.data.tags[0]}</span>}
              </div>
              <h3>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
              <a href={`/blog/${post.id}/`} class="c-blog-read-link">
                Read article
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="c-blog-empty">
          <h3>Articles are coming soon.</h3>
          <p>Published posts will appear here automatically.</p>
        </div>
      )
    }
  </div>
</section>
