---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<section id="blog" class="section home-blog-section">
  <div class="container">
    <div class="section-header">
      <span class="section-kicker">Writing</span>
      <h2 class="section-title">Field Notes From the Content Lab</h2>
    </div>

    <div class="home-blog-feature">
      <div class="home-blog-image">
        <img
          src="/images/blog/blog-cover.svg"
          alt="Abstract editorial illustration of technical content blocks connecting into a clear publishing system"
          loading="lazy"
          decoding="async"
          width="1600"
          height="900"
        />
      </div>
      <div class="home-blog-copy">
        <p class="blog-kicker">Blog</p>
        <h3>
          Useful thinking for technical marketers, founders, and product teams.
        </h3>
        <p>
          Notes on turning complex technology into clearer positioning, sharper
          content systems, and pages that help buyers understand what matters.
        </p>
        <a href="/blog/" class="btn btn--primary">View all posts</a>
      </div>
    </div>

    {
      posts.length > 0 ? (
        <div class="home-blog-grid" aria-label="Latest blog posts">
          {posts.map((post) => (
            <article class="home-blog-card">
              <div class="home-blog-card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.tags[0] && <span>{post.data.tags[0]}</span>}
              </div>
              <h3>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
              <a href={`/blog/${post.id}/`} class="blog-read-link">
                Read article
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="blog-empty">
          <h3>Articles are coming soon.</h3>
          <p>Published posts will appear here automatically.</p>
        </div>
      )
    }
  </div>
</section>
