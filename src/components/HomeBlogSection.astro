---
import { getCollection } from 'astro:content';
import { siteContent } from '../content.js';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);

const section = siteContent.sections.blog;
const { feature, readMoreLabel } = siteContent.blogSection;
const blogEmpty = siteContent.blogEmpty;
---

<section id="blog" class="c-section c-home-blog">
  <div class="c-section__header">
    <div class="o-container c-section__header-inner">
      <span class="c-section__kicker"
        ><span class="c-section__kicker-label">{section.kicker}</span></span
      >
      <h2 class="c-section__title">{section.title}</h2>
    </div>
  </div>
  <div class="o-container">
    <div class="c-home-blog__feature">
      <div class="c-home-blog__image">
        <img
          src={feature.image}
          alt={feature.imageAlt}
          loading="lazy"
          decoding="async"
          width="1600"
          height="900"
        />
      </div>
      <div class="c-home-blog__copy">
        <p class="c-blog-kicker">{feature.kicker}</p>
        <h3>{feature.heading}</h3>
        <p>{feature.text}</p>
        <a href="/blog/" class="c-btn c-btn--primary">{feature.ctaLabel}</a>
      </div>
    </div>

    {
      posts.length > 0 ? (
        <div class="c-home-blog__grid">
          {posts.map((post) => (
            <article class="c-home-blog__card">
              <div class="c-home-blog__card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.tags[0] && <span>{post.data.tags[0]}</span>}
              </div>
              <h3>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
              <a href={`/blog/${post.id}/`} class="c-blog-read-link">
                {readMoreLabel}
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="c-blog-empty">
          <h3>{blogEmpty.title}</h3>
          <p>{blogEmpty.homeText}</p>
        </div>
      )
    }
  </div>
</section>
