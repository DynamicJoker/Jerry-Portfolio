---
const { backHref = '#hero' } = Astro.props;
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-text">
        <p>&copy; <span id="footer-year">{new Date().getFullYear()}</span> Jerry James. All rights reserved.</p>
      </div>
      <div class="footer-links">
        <a href={backHref} class="footer-link">Back to Top</a>
      </div>
    </div>
  </div>
</footer>
