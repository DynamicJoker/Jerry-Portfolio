---
// Krub is the body face (all pages).
import bodyLatin400Url from '@fontsource/krub/files/krub-latin-400-normal.woff2?url';
import bodyLatin500Url from '@fontsource/krub/files/krub-latin-500-normal.woff2?url';
import bodyLatin600Url from '@fontsource/krub/files/krub-latin-600-normal.woff2?url';
// Inter variable (wght axis) is the display face for all headings (all pages).
import displayFontUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import globalStylesUrl from '../styles/global.css?url';
import criticalHomeStyles from '../styles/critical-home.css?raw';
import { siteContent, skillKeywords } from '../content.js';
import BetaBanner from '../components/BetaBanner.astro';

const profile = siteContent.profile;
const {
  title = profile.pageTitle,
  description = profile.description,
  canonical = new URL(Astro.url.pathname, profile.canonicalUrl).href,
  page = 'home',
  image = profile.socialImage,
  imageAlt = profile.socialImageAlt,
  imageWidth = profile.socialImageWidth,
  imageHeight = profile.socialImageHeight,
  type = 'website',
  structuredData = [],
  noindex = false,
} = Astro.props;

const personId = new URL('/#person', profile.canonicalUrl).href;

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': personId,
  name: profile.name,
  url: profile.canonicalUrl,
  image: new URL(profile.socialImage, profile.canonicalUrl).href,
  jobTitle: profile.jobTitle,
  address: {
    '@type': 'PostalAddress',
    addressLocality: profile.location.city,
    addressCountry: profile.location.country,
  },
  sameAs: profile.sameAs,
  knowsAbout: skillKeywords,
  description: profile.aiSummary,
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': new URL('/#website', profile.canonicalUrl).href,
  url: profile.canonicalUrl,
  name: profile.name,
  description: profile.description,
  publisher: {
    '@id': personId,
  },
  inLanguage: 'en',
};

const profilePageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': new URL('/#profile-page', profile.canonicalUrl).href,
  url: profile.canonicalUrl,
  name: profile.pageTitle,
  description: profile.description,
  image: new URL(profile.socialImage, profile.canonicalUrl).href,
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: new URL(profile.socialImage, profile.canonicalUrl).href,
    width: profile.socialImageWidth,
    height: profile.socialImageHeight,
  },
  mainEntity: {
    '@id': personId,
  },
  inLanguage: 'en',
};

const absoluteImage = new URL(image, profile.canonicalUrl).href;
const isHome = page === 'home';
const jsonLd = [
  personJsonLd,
  ...(isHome ? [websiteJsonLd, profilePageJsonLd] : []),
  ...structuredData,
];
const jsonLdHtml = jsonLd
  .map(
    (item) =>
      `<script type="application/ld+json">${JSON.stringify(item).replace(/</g, '\\u003c')}</script>`,
  )
  .join('\n');
const bodyFontFaces = [
  { weight: '400', url: bodyLatin400Url },
  { weight: '500', url: bodyLatin500Url },
  { weight: '600', url: bodyLatin600Url },
];
const bodyFontFaceCssHtml = `<style data-font-face="body">${bodyFontFaces
  .map(
    ({ weight, url }) =>
      `@font-face{font-family:'Krub';font-style:normal;font-display:swap;font-weight:${weight};src:url(${JSON.stringify(url)}) format('woff2');}`,
  )
  .join('')}</style>`;
const displayFontFaceCssHtml = `<style data-font-face="display">@font-face{font-family:'Inter';font-style:normal;font-display:swap;font-weight:100 900;src:url(${JSON.stringify(displayFontUrl)}) format('woff2-variations');}</style>`;
const criticalHomeCssHtml = `<style data-critical-css="home">${criticalHomeStyles.replace(/<\/style/gi, '<\\/style')}</style>`;
const homePortraitImage = profile.portraitImage;
const stylesheetHtml = isHome
  ? `${criticalHomeCssHtml}<script type="module" data-deferred-stylesheet>
const href=${JSON.stringify(globalStylesUrl)};
const loadStylesheet=()=>{
  if(document.querySelector('link[data-global-stylesheet]')) return;
  const link=document.createElement('link');
  link.rel='stylesheet';
  link.href=href;
  link.dataset.globalStylesheet='';
  // The deferred sheet finalises below-the-fold layout (e.g. the work filmstrip),
  // so any geometry measured before it lands (docked section headers, scroll-spy)
  // is stale. A resize once it applies re-runs those recalcs.
  link.addEventListener('load',()=>{window.dispatchEvent(new Event('resize'));},{once:true});
  document.head.append(link);
};
if('requestAnimationFrame' in window){
  requestAnimationFrame(()=>requestAnimationFrame(loadStylesheet));
}else{
  window.addEventListener('load',loadStylesheet,{once:true});
}
</script>`
  : `<link rel="stylesheet" href="${globalStylesUrl}">`;
const noScriptStylesheetHtml = isHome
  ? `<noscript><link rel="stylesheet" href="${globalStylesUrl}"></noscript>`
  : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Resolve the color scheme before any CSS so there is no wrong-theme
         flash. No JS = no attribute, and the prefers-color-scheme media
         block in the stylesheets takes over. -->
    <script is:inline>
      (() => {
        let stored = null;
        try {
          stored = localStorage.getItem('color-scheme');
        } catch {
          /* storage blocked: follow system */
        }
        const scheme =
          stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.dataset.colorScheme = scheme;
      })();
    </script>
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fafaf9"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#0f1117"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, nofollow'
        : 'index, follow, max-image-preview:large'}
    />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/brand/jj-signal-icon.svg" type="image/svg+xml" />
    <link
      rel="shortcut icon"
      href="/brand/jj-signal-icon.svg"
      type="image/svg+xml"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${profile.name} - Blog`}
      href={new URL('/rss.xml', profile.canonicalUrl).href}
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content={imageWidth} />
    <meta property="og:image:height" content={imageHeight} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
    {
      isHome &&
        bodyFontFaces.map((font) => (
          <link
            rel="preload"
            as="font"
            href={font.url}
            type="font/woff2"
            crossorigin
          />
        ))
    }
    {
      isHome && (
        <link
          rel="preload"
          as="font"
          href={displayFontUrl}
          type="font/woff2"
          crossorigin
        />
      )
    }
    {
      isHome && (
        <link
          rel="preload"
          as="image"
          href={homePortraitImage}
          fetchpriority="high"
        />
      )
    }
    <Fragment set:html={bodyFontFaceCssHtml} />
    <Fragment set:html={displayFontFaceCssHtml} />
    <Fragment set:html={stylesheetHtml} />
    <Fragment set:html={noScriptStylesheetHtml} />
    <noscript>
      <style>
        #loading-screen {
          display: none;
        }

        /* Sections are revealed by the scroll script; without JS show them all */
        .c-section {
          opacity: 1;
          transform: none;
        }

        #gantt-chart-container {
          opacity: 1;
        }

        #gantt-chart-container .c-gantt__bar {
          transform: none;
        }
      </style>
    </noscript>
    <Fragment set:html={jsonLdHtml} />
    <slot name="head" />
  </head>
  <body data-page={page}>
    <a class="c-skip-link" href="#main-content">Skip to content</a>
    <BetaBanner />
    <slot />
  </body>
</html>
